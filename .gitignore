# ===== Generated / derived artifacts =====
artifacts/predictions/
artifacts/eval/
out/

# Path C / SD inpaint eval outputs - patient faces in generated/ and grid.
# Keep metrics.json (small, PII-free) tracked explicitly via exclusion.
artifacts/eval_sd_inpaint/generated/
artifacts/eval_sd_inpaint/*.png
artifacts/eval_sd_inpaint/*.jpg

# V5 eval outputs - same rule (patient faces in generated/ and qualitative_grid.png).
# Keep milestone summaries + loss/FID plots tracked.
artifacts/eval_sd_inpaint_v5/*/generated/
artifacts/eval_sd_inpaint_v5/*/qualitative_grid.png
artifacts/eval_sd_inpaint_v5/*/*.jpg

# V6 eval outputs - same rule as V5.
artifacts/eval_sd_inpaint_v6/*/generated/
artifacts/eval_sd_inpaint_v6/*/qualitative_grid.png
artifacts/eval_sd_inpaint_v6/*/*.jpg

# V3 eval grids - contain patient faces. Keep benchmark.csv tracked.
artifacts/eval_v3_512/*/qualitative_grid.png
artifacts/eval_v3_512/*/*.jpg
artifacts/eval_v3_512/*/*.jpeg

